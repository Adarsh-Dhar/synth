generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

generator worker {
  provider = "prisma-client"
  output   = "../../worker/src/lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Enums to keep your data strictly typed
enum AgentStatus {
  STARTING
  RUNNING
  STOPPING
  STOPPED
  ERROR
}

enum StrategyType {
  MEME_SNIPER
  ARBITRAGE
  SENTIMENT_TRADER
}

enum LogType {
  INFO
  EXECUTION_BUY
  EXECUTION_SELL
  PROFIT_SECURED
  ERROR
}

model User {
  id        String   @id // Clerk User ID
  email     String   @unique
  name      String?
  walletAddress String @default("")
  subscriptionTier String  @default("FREE")
  monthlyUsageUnits Int    @default(0)
  agents    Agent[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Agent {
  id               String       @id @default(cuid())
  name             String
  status           AgentStatus  @default(STOPPED)
  userId           String
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  walletAddress    String       @default("")
  umbraViewingKey  String?      @db.Text
  umbraSpendingKey String?      @db.Text
  magicBlockSessionId String?   @db.Text
  magicBlockValidatorEndpoint String? @db.Text
  privateExecutionEnabled Boolean @default(false)
  umbraShieldedMint String?     @db.Text
  goldrushPortfolioSnapshot Json?
  goldrushStreamFilter String?  @db.Text
  configuration    Json?
  envConfig        String?      @db.Text // Encrypted .env (AES-256-GCM)
  tradeLogs        TradeLog[]
  subscriptions    Subscription[]
  terminalLogs     TerminalLog[] @relation("terminalLogs")
  files            AgentFile[]  // <-- NEW: Relation to bot code files
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

// NEW MODEL: Stores the generated code files for the agent
model AgentFile {
  id        String   @id @default(cuid())
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  filepath  String   // File route (e.g., "src/index.ts")
  content   String   @db.Text // Text content of the file
  language  String   @default("plaintext") // e.g., "typescript", "json"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([agentId, filepath])
}

model TradeLog {
  id              String   @id @default(cuid())
  agentId         String
  agent           Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  txHash          String   @unique
  tokenIn         String
  tokenOut        String
  amountIn        String
  amountOut       String
  profitUsd       String
  executionTimeMs Int
  createdAt       DateTime @default(now())
}

model Subscription {
  id                String   @id @default(cuid())
  agentId           String
  agent             Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  provider          String
  status            String
  externalReference String   @unique
  plan              String?
  webhookUrl        String?
  validUntil        DateTime?
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([agentId, provider])
  @@index([status])
  @@index([agentId, status])
  @@index([provider, plan])
}

model TerminalLog {
  id        String   @id @default(cuid())
  agentId   String
  agent     Agent    @relation("terminalLogs", fields: [agentId], references: [id], onDelete: Cascade)
  line      String   @db.Text
  level     String   // "stdout" or "stderr"
  timestamp DateTime @default(now())
}
