{
  "compilerOptions": {
    "module": "node16",
    "esModuleInterop": true,
    "target": "es2020",
    "moduleResolution": "node16",
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "baseUrl": "./src",
    "paths": {
      "@/*": ["*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "agents/generated/**/*"],
  "lib": ["es2015"]
}
