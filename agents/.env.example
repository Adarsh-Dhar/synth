# agents/.env.example — environment variables for agents

# AI model credentials
# GITHUB_TOKEN=github_pat_xxx
# AZURE_AI_KEY=xxx

# MCP / service endpoints
MCP_UPSTREAM_URL=http://127.0.0.1:8001
JUPITER_DOCS_MCP_URL=http://127.0.0.1:5001
DODO_DOCS_MCP_URL=http://127.0.0.1:5002

# Dodo integration keys
DODO_API_KEY=
DODO_PLAN_PRO_ID=
DODO_WEBHOOK_SECRET=

# Other helpful defaults
SOLANA_NETWORK=devnet
MCP_GATEWAY_URL=http://127.0.0.1:8001

# Context sizes
CONTEXT_INJECTION_MAX_CHARS=12000
JUPITER_DOCS_MAX_CHARS=4000
DODO_DOCS_MAX_CHARS=4000
